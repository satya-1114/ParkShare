APP_NAME=ParkShare API
APP_VERSION=0.3.0
DEBUG=true

# Generate a long random string in production
SECRET_KEY=change-me-to-a-long-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Async SQLAlchemy URL — must use the +asyncpg driver
DATABASE_URL=postgresql+asyncpg://parkshare:parkshare@localhost:5432/parkshare

CORS_ORIGINS=http://localhost:5173,http://localhost:8080

UPLOAD_DIRECTORY=./uploads
MAX_UPLOAD_SIZE=5242880

# IBM watsonx.ai
WATSONX_API_KEY=your-ibm-cloud-api-key
WATSONX_PROJECT_ID=your-watsonx-project-id
# Region-specific endpoint — MUST match your watsonx.ai Runtime region.
# Frankfurt = https://eu-de.ml.cloud.ibm.com, Dallas = https://us-south.ml.cloud.ibm.com
WATSONX_URL=https://eu-de.ml.cloud.ibm.com
WATSONX_MODEL_ID=ibm/granite-4-h-small
WATSONX_TIMEOUT_SECONDS=20
WATSONX_MAX_NEW_TOKENS=512
